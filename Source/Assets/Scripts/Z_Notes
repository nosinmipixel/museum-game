# Change music (Message)
logic.sendMessage("sound_background.set_context", "sound_background.set_context|quiz")

# Fade out
logic.sendMessage("sound_background.fade_out", "sound_background.fade_out")

# Stop music
logic.sendMessage("sound_background.stop", "sound_background.stop")

